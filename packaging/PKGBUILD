# Maintainer: Gamedirection
pkgname=perms
pkgver=0.2.0
pkgrel=1
pkgdesc="Linux filesystem permissions visualizer, auditor, and manager"
arch=('x86_64')
url="https://github.com/Gamedirection/perms"
license=('MIT')
depends=('gtk4' 'libadwaita' 'sqlite')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    cargo build --release --locked
}

package() {
    cd "$srcdir/$pkgname-$pkgver"

    # Main UI binary
    install -Dm755 "target/release/perms-ui" "$pkgdir/usr/bin/perms"

    # Privileged helper — not setuid; launched via polkit
    install -Dm755 "target/release/perms-helper" "$pkgdir/usr/libexec/perms-helper"

    # Polkit policy
    install -Dm644 "packaging/org.perms.helper.policy" \
        "$pkgdir/usr/share/polkit-1/actions/org.perms.helper.policy"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
